# ==========================================
# Flask / Python Environment
# ==========================================
# Virtual environments (local testing)
.venv/
venv/
ENV/
env/

# Python bytecode (compiled files)
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
# Never commit actual passwords, API keys, or Redis credentials
.env
.flaskenv
instance/
.pytest_cache/

# ==========================================
# Testing (Pytest)
# ==========================================
.pytest_cache/
.htmlcov/
.coverage
.coverage.*
coverage.xml

# ==========================================
# Docker & Databases
# ==========================================
# Ignore local Redis data dumps if they back up to your host machine
*.rdb

# ==========================================
# Operating System files
# ==========================================
.DS_Store
Thumbs.db

 Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout
